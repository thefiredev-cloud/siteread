{
  "name": "@thefiredev/siteread",
  "version": "0.1.0",
  "description": "Point a camera at any physical space. Get an operations manual in minutes.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/**/*.test.ts",
    "test:e2e": "vitest run tests/e2e",
    "coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.ts",
    "db:migrate": "tsx src/utils/migrate.ts",
    "db:seed": "tsx src/utils/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "computer-vision",
    "operations",
    "video-analysis",
    "ai",
    "bottleneck-detection",
    "operations-manual"
  ],
  "author": "The Fire Dev LLC <hello@thefiredev.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thefiredev/siteread.git"
  },
  "homepage": "https://thefiredev.com/siteread",
  "bugs": {
    "url": "https://github.com/thefiredev/siteread/issues"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.3.0",
    "zod": "^3.23.0",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.0",
    "ioredis": "^5.3.0",
    "bullmq": "^5.4.0",
    "openai": "^4.47.0",
    "aws-sdk": "^2.1600.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "prettier": "^3.3.0",
    "drizzle-kit": "^0.21.0",
    "@types/node": "^20.13.0",
    "@types/pg": "^8.11.0",
    "@types/fluent-ffmpeg": "^2.1.24"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
